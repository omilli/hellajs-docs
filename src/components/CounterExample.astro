<div id="root" class="flex justify-between items-center"></div>

<script>
  import { html, mount, signal } from "@hellajs/core";
  import { tw } from "../tw";

  const { $, button, span } = html;

  const count = signal(0);

  const setCount = (change: number) => count.set(count() + change);

  const styles = {
    button: tw`mt-4 rounded bg-[var(--sl-color-text-accent)] py-2 px-4 border border-transparent text-center text-sm text-[var(--sl-color-text-invert)] font-semibold active:transition-transform active:scale-90`,
    count: tw`mt-4 text-xl font-bold bg-slate-600 px-4 py-1.5 rounded-full text-white`,
  };

  const btn = (set: number, label: string) =>
    button(
      {
        className: styles.button,
        onclick: () => setCount(set),
      },
      label,
    );

  const Counter = () =>
    $(
      btn(-1, "Decrement"),
      span(
        {
          className: styles.count,
        },
        count(),
      ),
      btn(+1, "Increment"),
    );

  mount(Counter);
</script>
